# Required: Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Optional: Override the default recipient and sender
# CONTACT_EMAIL=hello@zachlamb.com
# RESEND_FROM_EMAIL=contact@yourdomain.com

# Optional: Email shown in the "Or reach out directly" mailto link (should match CONTACT_EMAIL).
# If unset, falls back to hello@zachlamb.com. Set in Vercel (or .env.local) when you want to change it.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@zachlamb.com

# Vercel KV (auto-provisioned when you create a KV store in Vercel dashboard)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Google OAuth for /myspace/admin dashboard
# Create credentials at https://console.cloud.google.com/apis/credentials
# AUTH_SECRET=          # Generate with: openssl rand -base64 33
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Admin email (Google account) allowed to access /myspace/admin
# MYSPACE_ADMIN_USERNAME=you@gmail.com
