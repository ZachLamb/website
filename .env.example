# Required: Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Required in production: sender address for the contact form.
# Must be a verified domain in Resend. If unset, the contact route will 500 in production.
# RESEND_FROM_EMAIL=contact@zachlamb.com

# Optional: Where the contact form forwards messages (defaults to hello@zachlamb.com).
# CONTACT_EMAIL=hello@zachlamb.com

# Optional: Email shown in the "Or reach out directly" mailto link (should match CONTACT_EMAIL).
# If unset, falls back to hello@zachlamb.com. Set in Vercel (or .env.local) to override.
# NEXT_PUBLIC_CONTACT_EMAIL=hello@zachlamb.com
